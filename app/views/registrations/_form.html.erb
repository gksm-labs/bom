<%= form_with model: registration,
              id: "raceRegistrationForm",
              class: "rounded-2xl bg-white p-4 shadow-sm sm:p-8",
              data: { controller: "form-stepper" } do |f| %>

  <div id="formProgressHeader" class="mb-8">
    <div class="select-none flex items-center gap-2 sm:gap-4">
      <% 3.times do |i| %>
        <div data-form-stepper-target="dot" class="step-dot flex h-8 w-8 items-center transition-all duration-300 justify-center rounded-full bg-slate-300 text-xs font-bold text-slate-700 sm:h-9 sm:w-9 sm:text-sm">
          <%= i + 1 %>
        </div>
        <% if i < 2 %><div class="h-1 flex-1 rounded bg-slate-200"></div><% end %>
      <% end %>
    </div>
    <p class="mt-3 text-sm text-slate-600">
      Krok <span data-form-stepper-target="currentStepText">1</span> z 3:
      <span data-form-stepper-target="currentStepLabel" class="font-semibold text-slate-800">Osobné údaje</span>
    </p>
  </div>

  <div data-form-stepper-target="panel" class="step-panel">
    <h3 class="font-display font-bold text-2xl text-primary">Osobné údaje</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Meno *</span>
        <%= f.text_field :first_name, required: true, class: "rounded-md border border-slate-300 px-3 py-2" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Priezvisko *</span>
        <%= f.text_field :last_name, required: true, class: "rounded-md border border-slate-300 px-3 py-2" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Dátum narodenia *</span>
        <%= f.date_field :birth_date, required: true, class: "rounded-md border border-slate-300 px-3 py-2" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">E-mail *</span>
        <%= f.email_field :email, required: true, class: "rounded-md border border-slate-300 px-3 py-2" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Telefón *</span>
        <%= f.telephone_field :phone, required: true, class: "rounded-md border border-slate-300 px-3 py-2" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Pohlavie *</span>
        <%= f.select :gender, [["Muž", "muz"], ["Žena", "zena"], ["Nechcem uviesť", "neurcene"]], { prompt: "Vyberte" }, required: true, class: "rounded-md border border-slate-300 px-3 py-2 bg-white" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Mesto/Obec *</span>
        <%= f.text_field :city, required: true, class: "rounded-md border border-slate-300 px-3 py-2" %>
      </label>
    </div>
  </div>

  <div data-form-stepper-target="panel" class="step-panel hidden">
    <h3 class="font-display font-bold text-2xl text-primary">Údaje o behu</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Disciplína *</span>
        <%= f.select :discipline, [["Hlavný beh 10 km", "10km"], ["Hobby beh 5 km", "5km"]], { prompt: "Vyberte" }, required: true, class: "rounded-md border border-slate-300 px-3 py-2 bg-white" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Kategória *</span>
        <%= f.select :category, [["Muži", "M"], ["Ženy", "Z"]], { prompt: "Vyberte" }, required: true, class: "rounded-md border border-slate-300 px-3 py-2 bg-white" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Veľkosť trička *</span>
        <%= f.select :t_shirt_size, %w[XS S M L XL XXL], { prompt: "Vyberte" }, required: true, class: "rounded-md border border-slate-300 px-3 py-2 bg-white" %>
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium text-slate-700">Klub / tím</span>
        <%= f.text_field :club, class: "rounded-md border border-slate-300 px-3 py-2" %>
      </label>
    </div>
  </div>

  <div data-form-stepper-target="panel" class="step-panel hidden">
    <h3 class="font-display font-bold text-2xl text-primary">Potvrdenie a súhlasy</h3>
    <div class="mt-5 space-y-3 rounded-xl bg-slate-50 p-4">
      <label class="flex items-start gap-3">
        <%= f.check_box :gdpr_consent, required: true, class: "mt-1 h-4 w-4 accent-red" %>
        <span class="text-sm text-slate-700">Súhlasím so spracovaním osobných údajov (GDPR). *</span>
      </label>
      <label class="flex items-start gap-3">
        <%= f.check_box :terms_consent, required: true, class: "mt-1 h-4 w-4 accent-red" %>
        <span class="text-sm text-slate-700">Súhlasím s pravidlami a propozíciami podujatia. *</span>
      </label>
    </div>
  </div>

  <div class="mt-8 flex items-center gap-3">
    <button type="button" data-form-stepper-target="prevBtn" data-action="click->form-stepper#prev" class="hidden btn-outline !bg-slate-200 !text-slate-700 hover:!bg-slate-300">Späť</button>
    <button type="button" data-form-stepper-target="nextBtn" data-action="click->form-stepper#next" class="btn-red !bg-primary">Pokračovať</button>
    <%= f.button "Odoslať registráciu", data: { form_stepper_target: "submitBtn" }, class: "hidden btn-red" %>
  </div>

<% end %>
