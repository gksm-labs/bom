<section class="bg-primary text-white">
  <div class="mx-auto flex h-[15rem] max-w-6xl items-center justify-center px-4 text-center sm:h-[18rem]">
    <h1 class="font-display text-5xl leading-none tracking-tight sm:text-7xl">
      Registrácia na <span class="block text-green">Beh okolo Modry</span>
    </h1>
  </div>
</section>

<%= render "info" %>

<section id="registracia" class="bg-slate-50">
  <div class="relative mx-auto max-w-4xl px-4 py-8 sm:py-12">

    <% if @registration_closed %>
      <div class="absolute inset-0 z-30 mx-4 my-8 sm:my-12 rounded-2xl bg-white/60 backdrop-blur-[2px] p-5 sm:p-8 flex items-center justify-center">
        <div class="mx-auto flex flex-col items-center justify-center text-center bg-white p-8 rounded-2xl shadow-lg border border-slate-100 max-w-md">
          <h3 class="font-display text-4xl leading-none text-primary sm:text-5xl">
            zabehli ste príliš skoro
          </h3>
          <p class="mt-3 text-base text-slate-700 sm:text-lg">
            Registrácia ešte nie je otvorená.
          </p>
          <div class="mt-6 w-full">
            <a href="<%= root_path %>" class="btn-outline w-full justify-center !bg-slate-200 !text-slate-700 hover:!bg-slate-300">
              Späť na hlavnú stránku
            </a>
          </div>
        </div>
      </div>
    <% end %>

    <div class="<%= 'opacity-40 grayscale-[30%] pointer-events-none select-none' if @registration_closed %>">
      <%= render "form", registration: @registration %>
    </div>

  </div>
</section>
