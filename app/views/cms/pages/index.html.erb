<% content_for :title, "#{@category.name} | Beh okolo Modry" %>

<div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-20 lg:px-8 min-h-[75vh]">
  <div class="mb-10">
    <%= link_to root_path, class: "group inline-flex items-center text-sm font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors" do %>
      <div class="mr-3 flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 group-hover:bg-primary group-hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" /></svg>
      </div>
      Späť
    <% end %>
  </div>

  <header class="mb-12 border-b border-slate-200 pb-8 sm:mb-16">
    <h1 class="font-display text-5xl font-bold leading-none tracking-tight text-primary sm:text-7xl">
      <%= @category.name %>
    </h1>
  </header>

  <div class="flex flex-col">
    <% @pages.each do |page| %>
      <%= link_to cms_page_path([@category.slug, page.slug].compact.join('/')), class: "group flex flex-col sm:flex-row sm:items-center justify-between border-b border-slate-100 py-6 transition-all hover:bg-slate-50 sm:px-4 -mx-4 rounded-xl" do %>

        <div class="flex flex-col gap-1 sm:gap-2">
          <h2 class="font-display text-3xl font-bold text-slate-900 group-hover:text-primary transition-colors">
            <%= page.title %>
          </h2>
          <div class="text-sm font-medium text-slate-500">
            Publikované <%= l page.created_at.to_date %>
          </div>
        </div>

        <div class="mt-4 sm:mt-0 flex items-center justify-between text-sm font-bold text-green">
          <span class="sm:hidden">Zobraziť</span>
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green/10 group-hover:bg-green group-hover:text-white transition-colors text-green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
          </div>
        </div>

      <% end %>
    <% end %>

    <% if @pages.empty? %>
      <div class="py-12 text-center text-slate-500 font-medium">
        Zatiaľ tu nie sú žiadne dokumenty.
      </div>
    <% end %>
  </div>
</div>
