<% content_for :title, "#{@page.title} | Beh okolo Modry" %>

<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-20 lg:px-8">
  <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
    <aside class="lg:col-span-3">
      <div class="sticky top-28 space-y-8">
        <%= link_to (request.referer || root_path), class: "group inline-flex items-center text-sm font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors" do %>
          <div class="mr-3 flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 group-hover:bg-primary group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" /></svg>
          </div>
          Späť
        <% end %>

        <div class="hidden lg:block border-t border-slate-200 pt-6">
          <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Publikované</p>
          <p class="mt-1 font-medium text-slate-900"><%= l @page.created_at.to_date, format: :long %></p>
        </div>

        <% if @category %>
          <div class="hidden lg:block border-t border-slate-200 pt-6">
            <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Kategória</p>
            <p class="mt-1 font-medium text-green"><%= @category.name %></p>
          </div>
        <% end %>
      </div>
    </aside>

    <article class="lg:col-span-8 lg:col-start-5">
      <header class="mb-10 sm:mb-16">
        <% if @category %>
          <p class="lg:hidden text-sm font-bold uppercase tracking-widest text-green mb-4"><%= @category.name %></p>
        <% end %>

        <h1 class="font-display text-5xl font-bold leading-none tracking-tight text-primary sm:text-7xl">
          <%= @page.title %>
        </h1>

        <p class="mt-6 text-base font-medium text-slate-500 lg:hidden">
          <%= l @page.created_at.to_date, format: :long %>
        </p>
      </header>

      <div class="cms-content max-w-prose">
        <%= sanitize @page.content, tags: %w(p strong i em a img h2 h3 h4 h5 div ol ul li br table tr td th thead tbody), attributes: %w(href alt class title style target src) %>
      </div>
    </article>
  </div>
</div>
