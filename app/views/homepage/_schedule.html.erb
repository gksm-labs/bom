<div class="section-container">
  <div class="max-w-3xl">
    <h2 class="heading-primary">Program podujatia</h2>
    <p class="mt-3 text-base leading-relaxed text-slate-700 sm:text-lg">
      Harmonogram dňa. Odporúčame prísť aspoň 45 minút pred štartom vašej kategórie.
    </p>
  </div>

  <div class="mt-10 grid gap-4 sm:gap-5">
    <div class="rounded-2xl bg-white p-5 sm:p-6">
      <% if current_edition&.schedule_items&.any? %>
        <ol class="space-y-4">
          <% current_edition.schedule_items.each do |item| %>
            <li class="flex items-start gap-4">
              <div class="min-w-20 rounded-md <%= schedule_badge_class(item.badge_color) %> px-3 py-1.5 text-center text-sm font-bold text-white">
                <%= item.start_time.strftime("%H:%M") %>
              </div>
              <div>
                <p class="font-semibold text-slate-900"><%= item.title %></p>
                <% if item.description.present? %>
                  <p class="text-sm text-slate-600"><%= item.description %></p>
                <% end %>
              </div>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-slate-600 italic">Program bude čoskoro zverejnený.</p>
      <% end %>
    </div>
  </div>
</div>
