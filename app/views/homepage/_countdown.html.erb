<% if @current_edition %>
  <div class="relative overflow-hidden bg-primary px-4 py-16 sm:py-24 lg:py-32">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>

    <div class="relative z-10 mx-auto max-w-4xl text-center">
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl text-white tracking-wide">
        Štartujeme o
      </h1>

      <div
        class="mt-6 mb-10"
        data-controller="countdown"
        data-countdown-date-value="<%= @current_edition.date.iso8601 %>"
      >
        <div
          data-countdown-target="display"
          class="font-mono text-5xl sm:text-7xl lg:text-8xl font-bold text-green tracking-tight drop-shadow-lg"
        >
          00d 00h 00m 00s
        </div>
      </div>

      <% if @current_edition.registration_open? %>
        <%= link_to new_registration_path, class: "group relative inline-flex items-center justify-center overflow-hidden rounded-md bg-red px-8 py-4 font-bold text-lg text-white transition hover:opacity-95 shadow-xl shadow-red/20" do %>
          <div class="pointer-events-none absolute inset-y-0 -left-[40%] w-1/3 -skew-x-12 bg-white/30 group-hover:translate-x-[450%] group-hover:transition-transform group-hover:duration-800 group-hover:ease-out"></div>
          <span class="relative z-10">Zabezpečiť si miesto</span>
        <% end %>
      <% else %>
        <p class="text-lg font-medium text-white/70">Registrácia je momentálne uzavretá.</p>
      <% end %>
    </div>
  </div>
<% end %>
