
<div class="section-container">
  <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
    <div>
      <h2 class="heading-primary">Kontakt</h2>
      <p class="mt-3 text-slate-700 sm:text-lg">
        Máte otázky k registrácii, trase alebo programu? Ozvite sa nám.
      </p>

      <div class="mt-6 space-y-3 text-slate-700">
        <p><span class="font-semibold text-slate-900">E-mail:</span> info@behokolomodry.sk</p>
        <p><span class="font-semibold text-slate-900">Telefón:</span> +421 900 123 456</p>
        <p><span class="font-semibold text-slate-900">Adresa:</span> Športová 12, 900 01 Modra</p>
      </div>
    </div>

    <form class="rounded-2xl bg-white p-5 sm:p-6">
      <div class="grid gap-4">
        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Meno</span>
          <input type="text" class="rounded-md border border-slate-300 px-3 py-2 text-slate-900 outline-none focus:border-primary" placeholder="Vaše meno" />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">E-mail</span>
          <input type="email" class="rounded-md border border-slate-300 px-3 py-2 text-slate-900 outline-none focus:border-primary" placeholder="vas@email.sk" />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Správa</span>
          <textarea rows="5" class="rounded-md border border-slate-300 px-3 py-2 text-slate-900 outline-none focus:border-primary" placeholder="Napíšte nám..."></textarea>
        </label>

        <button type="submit" class="btn-red w-full sm:w-auto sm:place-self-start">
          Odoslať správu
        </button>
      </div>
    </form>
  </div>
</div>
