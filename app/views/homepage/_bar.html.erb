<% if current_edition %>
  <div class="sticky top-20 z-40 bg-slate-100 border-b border-slate-200 shadow-sm">
    <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">

      <div class="flex items-center gap-2.5">
        <% if current_edition.registration_open? %>
          <div class="relative flex h-2.5 w-2.5 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green"></span>
          </div>
          <p class="text-xs sm:text-sm font-semibold uppercase tracking-wider text-slate-700">
            Registrácia <span class="text-green">spustená</span>
          </p>
        <% else %>
          <div class="h-2 w-2 rounded-full bg-slate-400 shrink-0"></div>
          <p class="text-xs sm:text-sm font-semibold uppercase tracking-wider text-slate-500">
            Registrácia <span class="text-slate-500">uzavretá</span>
          </p>
        <% end %>
      </div>

      <div class="flex w-full items-center gap-3 sm:max-w-[340px]">
        <span class="shrink-0 text-xs text-slate-600">
          Prihlásených <strong class="text-primary font-bold"><%= current_edition.registered_count %></strong> z <strong class="text-slate-800"><%= current_edition.max_capacity %></strong> bežcov
        </span>
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-200">
          <% percentage = (current_edition.registered_count.to_f / current_edition.max_capacity * 100).clamp(0, 100) %>
          <div class="h-full rounded-full transition-all duration-1000 <%= current_edition.registration_open? ? 'bg-primary' : 'bg-slate-400' %>" style="width: <%= percentage %>%"></div>
        </div>
      </div>

    </div>
  </div>
<% end %>
