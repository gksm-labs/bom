<div class="section-container">
  <div class="max-w-3xl">
    <h2 class="heading-primary">Organizátori a partneri</h2>
    <p class="mt-3 text-base leading-relaxed text-slate-700 sm:text-lg">
      Podujatie vzniká vďaka organizátorom, partnerom a komunite.
    </p>
  </div>

  <div class="mt-10">
    <h3 class="text-lg font-semibold text-primary">Organizátori</h3>
    <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Organizátor 1", class: "h-12 w-full object-contain" %>
      </a>
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Organizátor 2", class: "h-12 w-full object-contain" %>
      </a>
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Organizátor 3", class: "h-12 w-full object-contain" %>
      </a>
    </div>
  </div>

  <div class="mt-12">
    <h3 class="text-lg font-semibold text-primary">Hlavní partneri</h3>
    <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Partner 1", class: "h-12 w-full object-contain" %>
      </a>
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Partner 2", class: "h-12 w-full object-contain" %>
      </a>
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Partner 3", class: "h-12 w-full object-contain" %>
      </a>
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Partner 4", class: "h-12 w-full object-contain" %>
      </a>
    </div>
  </div>

  <div class="mt-12">
    <h3 class="text-lg font-semibold text-primary">Mediálni partneri</h3>
    <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Mediálny partner 1", class: "h-10 w-full object-contain" %>
      </a>
      <a href="#" class="rounded-xl bg-slate-50 p-4 transition hover:bg-slate-100">
        <%= image_tag "gksm.png", alt: "Mediálny partner 2", class: "h-10 w-full object-contain" %>
      </a>
    </div>
  </div>

  <div class="mt-12 rounded-2xl bg-slate-50 p-6 sm:p-8">
    <h3 class="text-lg font-semibold text-primary">Podporili nás</h3>
    <p class="mt-2 text-slate-700">
      Dobrovoľníci, lokálne firmy a športová komunita mesta Modra.
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      <span class="rounded-full bg-white px-3 py-1 text-sm text-slate-700">Dobrovoľníci Modra</span>
      <span class="rounded-full bg-white px-3 py-1 text-sm text-slate-700">Športový klub Modra</span>
      <span class="rounded-full bg-white px-3 py-1 text-sm text-slate-700">Miestne vinárstva</span>
      <span class="rounded-full bg-white px-3 py-1 text-sm text-slate-700">Komunitné centrum</span>
    </div>
  </div>
</div>
