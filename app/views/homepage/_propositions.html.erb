<div class="section-container">
  <div class="max-w-3xl">
    <h2 class="heading-primary">Propozície</h2>
    <p class="mt-3 text-base leading-relaxed text-slate-700 sm:text-lg">
      Prečítaj si dôležité informácie k podujatiu: pravidlá, trasu, GDPR a pokyny pre účastníkov.
    </p>
  </div>

  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <%= link_to cms_page_path("propositions/propozicie-2026"), class: "rounded-xl bg-white p-4 transition hover:bg-slate-100 shadow-sm border border-slate-100" do %>
      <p class="font-semibold text-slate-900">Oficiálne propozície</p>
      <p class="text-sm text-slate-500">Čítať viac</p>
    <% end %>

    <%= link_to cms_page_path("propositions/trasa-10km"), class: "rounded-xl bg-white p-4 transition hover:bg-slate-100 shadow-sm border border-slate-100" do %>
      <p class="font-semibold text-slate-900">Trasa 10 km</p>
      <p class="text-sm text-slate-500">Čítať viac</p>
    <% end %>

    <%= link_to cms_page_path("propositions/pokyny-pretekari"), class: "rounded-xl bg-white p-4 transition hover:bg-slate-100 shadow-sm border border-slate-100" do %>
      <p class="font-semibold text-slate-900">Pokyny pre pretekárov</p>
      <p class="text-sm text-slate-500">Čítať viac</p>
    <% end %>

    <%= link_to cms_page_path("propositions/gdpr-suhlas"), class: "rounded-xl bg-white p-4 transition hover:bg-slate-100 shadow-sm border border-slate-100" do %>
      <p class="font-semibold text-slate-900">GDPR a súhlasy</p>
      <p class="text-sm text-slate-500">Čítať viac</p>
    <% end %>
  </div>
</div>
