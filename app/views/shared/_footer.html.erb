<footer class="bg-primary text-white">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <a href="/">
          <%= image_tag "logo.png", alt: "logo", class: "h-10 w-auto object-contain" %>
        </a>
        <p class="mt-3 max-w-md text-sm text-white/80">
          Komunitné bežecké podujatie v srdci prírody mesta Modra.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-white/90">Rýchle odkazy</h3>
        <ul class="mt-3 space-y-2 text-sm text-white/80">
          <% navigation_links.each do |link| %>
            <li>
              <%= link_to link[:name], link[:path], class: "hover:text-white", data: { turbo: false } %>
            </li>
          <% end %>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-white/90">Kontakt</h3>
        <ul class="mt-3 space-y-2 text-sm text-white/80">
          <li><a href="mailto:info@behokolomodry.sk" class="hover:text-white">info@behokolomodry.sk</a></li>
          <li><a href="tel:+421000000000" class="hover:text-white">+421 000 000 000</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-white/20 pt-4 text-xs text-white/70">
      © <%= Date.current.year %> Beh okolo Modry. Všetky práva vyhradené.
    </div>
  </div>
</footer>